{
    "name": "@shocae/control",
    "version": "0.0.1",
    "private": true,
    "description": "shocae control",
    "homepage": "https://github.com/leoconforti/fish-bowl",
    "repository": {
        "type": "git",
        "url": "https://github.com/leoconforti/fish-bowl.git",
        "directory": "packages/control"
    },
    "license": "GPL-3.0-only",
    "author": "Leo Conforti <leo@leoconforti.us> (https://leoconforti.us)",
    "type": "module",
    "scripts": {
        "build": "pnpm build-esm && pnpm build-annotate && pnpm build-cjs && build-utils pack-v2",
        "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
        "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
        "build-esm": "tsc -b tsconfig.build.json",
        "check": "tsc -b tsconfig.json",
        "codegen": "build-utils prepare-v2"
    },
    "dependencies": {
        "@shocae/emulator": "workspace:^",
        "the-moby-effect": "1.45.0-alpha.21"
    },
    "devDependencies": {
        "@effect/platform": "0.72.0",
        "effect": "3.12.0"
    },
    "peerDependencies": {
        "@effect/platform": "0.72.0",
        "effect": "3.12.0"
    }
}
